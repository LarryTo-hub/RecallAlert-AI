# .env.production — Template for Cloud Run deployment
# Copy values from Google Secret Manager or set directly

# Environment
ENVIRONMENT=production
STORE_BACKEND=firebase

# API Keys (store in Google Secret Manager, NOT in .env)
GOOGLE_API_KEY=your-gemini-key-from-aistudio.google.com
TELEGRAM_BOT_TOKEN=123456:ABCdefGHIjklMNOpqrsTUVwxyz

# Firebase/Firestore
FIREBASE_CRED_PATH=/secrets/firebase-cred.json

# Polling
FETCH_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=INFO

# Optional: Cloud Run specific
PORT=8080
