# .env.render — Template for Render Deployment
# Copy values to Render dashboard Environment Variables

# Production settings
ENVIRONMENT=production
STORE_BACKEND=firebase

# API Configuration
GOOGLE_API_KEY=your-gemini-key-from-aistudio.google.com
JWT_SECRET_KEY=your-jwt-secret-key-from-python-secrets
FIREBASE_CRED_PATH=/tmp/firebase-cred.json

# CORS - allow your frontend domain
ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://www.your-app.com

# Polling
FETCH_INTERVAL_MINUTES=60

# Logging
LOG_LEVEL=INFO

# Port (Render provides this)
PORT=10000

# Optional: Database URL (for SQLite in dev, not used in prod)
DATABASE_URL=sqlite:///recalls.db
